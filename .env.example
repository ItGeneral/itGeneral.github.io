# EmailJS 配置示例
# 获取方式：
# 1. 访问 https://www.emailjs.com/ 注册账号
# 2. 创建邮件服务（选择 Gmail 或其他邮件提供商）
# 3. 创建邮件模板，使用以下模板变量：
#    {{feedback_type}} - 反馈类型
#    {{feedback_content}} - 反馈内容
#    {{user_email}} - 用户邮箱
#    {{timestamp}} - 时间戳
# 4. 在 EmailJS 控制台获取以下 ID 并填入：

VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Plausible Analytics 配置示例
# 复制此文件为 .env 并根据需要修改

# Plausible 域名（你的网站域名）
VITE_PLAUSIBLE_DOMAIN=itgeneral.github.io

# Plausible 脚本地址
VITE_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# 是否启用统计（生产环境）
VITE_PLAUSIBLE_ENABLED=true

# 是否启用调试模式（开发环境可启用查看日志）
VITE_PLAUSIBLE_DEBUG=false
